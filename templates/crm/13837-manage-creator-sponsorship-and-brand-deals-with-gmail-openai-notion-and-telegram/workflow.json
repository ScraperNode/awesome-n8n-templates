    {
      "id": "b3b842b3-59b6-4a0d-b3f6-32982830b833",
      "name": "\ud83d\udcca Calculate Revenue Stats",
      "type": "n8n-nodes-base.code",
      "position": [
        1440,
        2352
      ],
      "parameters": {
        "jsCode": "const deals = $input.all();\nconst now = new Date();\nconst targetMonth = now.getMonth() === 0 ? 11 : now.getMonth() - 1;\nconst targetYear = now.getMonth() === 0 ? now.getFullYear() - 1 : now.getFullYear();\n\nlet totalRevenue = 0;\nlet dealCount = 0;\nconst dealList = [];\nconst campaignBreakdown = {};\nconst channelBreakdown = {};\n\nfor (const deal of deals) {\n  const props = deal.json.properties;\n  const lastContact = props['Last Contact']?.date?.start;\n  if (lastContact) {\n    const dealDate = new Date(lastContact);\n    if (dealDate.getMonth() === targetMonth && dealDate.getFullYear() === targetYear) {\n      const revenue = props['Revenue']?.number || 0;\n      const company = props['Company Name']?.title[0]?.plain_text || 'Unknown';\n      const campaign = props['Campaign Type']?.select?.name || 'Unknown';\n      const channel = props['Channel']?.select?.name || 'Unknown';\n      totalRevenue += revenue;\n      dealCount++;\n      dealList.push({ company, revenue, campaign, channel });\n      campaignBreakdown[campaign] = (campaignBreakdown[campaign] || 0) + revenue;\n      channelBreakdown[channel] = (channelBreakdown[channel] || 0) + revenue;\n    }\n  }\n}\n\nconst monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];\nreturn [{\n  json: {\n    report_month: monthNames[targetMonth],\n    report_year: targetYear,\n    total_revenue: totalRevenue,\n    deal_count: dealCount,\n    deal_list: JSON.stringify(dealList),\n    campaign_breakdown: JSON.stringify(campaignBreakdown),\n    channel_breakdown: JSON.stringify(channelBreakdown),\n    avg_deal_value: dealCount > 0 ? Math.round(totalRevenue / dealCount) : 0\n  }\n}];"
      },
      "typeVersion": 2
    },
