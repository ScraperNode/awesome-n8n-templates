    {
      "id": "cb97ffb0-373f-4597-b0c2-04ffdf10e9c4",
      "name": "\ud83e\udde0 LLM - Classify and Extract",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "position": [
        1408,
        1296
      ],
      "parameters": {
        "text": "=You are an AI assistant that analyzes emails for a content creator.\n\nEmail From: {{ $('\ud83d\udd27 Extract Email Data').item.json.email_from_name }} <{{ $('\ud83d\udd27 Extract Email Data').item.json.email_from }}>\nSubject: {{ $('\ud83d\udd27 Extract Email Data').item.json.email_subject }}\nBody: {{ $('\ud83d\udd27 Extract Email Data').item.json.email_body }}\n\nAnalyze this email and respond ONLY with valid JSON (no markdown, no extra text):\n{\n  \"is_sponsorship\": true,\n  \"confidence\": 85,\n  \"company_name\": \"ACME Corp\",\n  \"contact_name\": \"John Smith\",\n  \"proposed_budget\": \"$500\",\n  \"campaign_type\": \"Integration\",\n  \"channel_requested\": \"YouTube\",\n  \"key_details\": \"They want a 60-second integration in your next video.\",\n  \"suggested_reply_tone\": \"Interested\"\n}\n\nFor is_sponsorship: true if this is a brand deal or sponsorship inquiry, false otherwise.\nFor campaign_type use: Integration, Dedicated Video, Newsletter Shoutout, UGC, Affiliate, or Unknown.\nFor channel_requested use: YouTube, Newsletter, X, Instagram, Multiple, or Unknown.\nFor suggested_reply_tone use: Interested, Need more info, Decline, or Follow-up later.",
        "promptType": "define"
      },
      "typeVersion": 1.4
    },
    {
      "id": "92b40b99-1813-4d06-8fb1-ff86009dfffd",
      "name": "\u2699\ufe0f Parse AI Response",
      "type": "n8n-nodes-base.code",
      "position": [
        1712,
        1296
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json.text || $input.first().json.response || '';\nlet parsed;\ntry {\n  const jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(jsonMatch ? jsonMatch[0] : raw);\n} catch(e) {\n  parsed = {\n    is_sponsorship: false,\n    confidence: 0,\n    company_name: 'Unknown',\n    contact_name: '',\n    proposed_budget: 'Not mentioned',\n    campaign_type: 'Unknown',\n    channel_requested: 'Unknown',\n    key_details: 'Could not parse AI response',\n    suggested_reply_tone: 'Need more info'\n  };\n}\n\nconst emailData = $('\ud83d\udd27 Extract Email Data').first().json;\n\nreturn [{\n  json: {\n    is_sponsorship: parsed.is_sponsorship === true,\n    confidence: parsed.confidence || 0,\n    company_name: parsed.company_name || 'Unknown',\n    contact_name: parsed.contact_name || emailData.email_from_name,\n    proposed_budget: parsed.proposed_budget || 'Not mentioned',\n    campaign_type: parsed.campaign_type || 'Unknown',\n    channel_requested: parsed.channel_requested || 'Unknown',\n    key_details: parsed.key_details || '',\n    suggested_reply_tone: parsed.suggested_reply_tone || 'Need more info',\n    email_from: emailData.email_from,\n    email_from_name: emailData.email_from_name,\n    email_subject: emailData.email_subject,\n    email_body: emailData.email_body,\n    email_date: emailData.email_date,\n    email_id: emailData.email_id\n  }\n}];"
      },
      "typeVersion": 2
    },
    {
