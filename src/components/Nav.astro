---
const base = import.meta.env.BASE_URL;
const navItems = [
  { text: 'Home', href: base },
  { text: 'Categories', href: `${base}templates/` },
  { text: 'Use Cases', href: `${base}use-cases/` },
  { text: 'Integrations', href: `${base}integrations/` },
  { text: 'Guides', href: `${base}docs/importing-templates/` },
  { text: 'ScraperNode', href: `${base}docs/scrapernode-guide/` },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a href={base} class="nav-brand">Awesome n8n</a>
    <div class="nav-links">
      {navItems.map(item => (
        <a href={item.href} class="nav-link">{item.text}</a>
      ))}
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    padding: 0 1.5rem;
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 56px;
  }
  .nav-brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: #ff6d5a;
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-links {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
  }
  .nav-link {
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: #ff6d5a;
  }
  @media (max-width: 640px) {
    .nav-links { gap: 0.75rem; }
    .nav-link { font-size: 0.8rem; }
  }
</style>
