---
interface Props {
  show?: boolean;
}
const { show = false } = Astro.props;
---

{show && (
  <div class="scrapernode-banner">
    <div class="banner-content">
      <div class="banner-icon">🕷️</div>
      <div class="banner-text">
        <strong>Supercharge your scraping with ScraperNode</strong>
        <p>Scrape LinkedIn, Instagram, TikTok, YouTube & more — directly in n8n. No code required.</p>
      </div>
      <div class="banner-actions">
        <a href="https://useweld.com" target="_blank" rel="noopener" class="banner-btn primary">Get Started Free</a>
        <a href={`${import.meta.env.BASE_URL}docs/scrapernode-guide/`} class="banner-btn secondary">Learn More</a>
      </div>
    </div>
  </div>
)}

<style>
  .scrapernode-banner {
    margin: 1.5rem 0;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    background: linear-gradient(135deg, #ff6d5a 0%, #ff8a65 100%);
    color: white;
  }
  .banner-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .banner-icon { font-size: 2rem; flex-shrink: 0; }
  .banner-text { flex: 1; min-width: 200px; }
  .banner-text strong { font-size: 1.1rem; display: block; margin-bottom: 0.25rem; }
  .banner-text p { margin: 0; opacity: 0.9; font-size: 0.9rem; }
  .banner-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
  .banner-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .banner-btn:hover { opacity: 0.9; }
  .banner-btn.primary { background: white; color: #ff6d5a; }
  .banner-btn.secondary {
    background: rgba(255,255,255,0.2);
    color: white;
    border: 1px solid rgba(255,255,255,0.4);
  }
  @media (max-width: 640px) {
    .banner-content { flex-direction: column; text-align: center; }
    .banner-actions { width: 100%; justify-content: center; }
  }
</style>
