    {
      "id": "39f8176d-1380-4bce-b63e-01d4806c32e3",
      "name": "\u270d\ufe0f LLM - Draft Reply",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "position": [
        3120,
        1200
      ],
      "parameters": {
        "text": "=You are a professional content creator assistant. Draft a reply email for a sponsorship inquiry.\n\nFrom: {{ $('\u2699\ufe0f Parse AI Response').item.json.email_from_name }}\nCompany: {{ $('\u2699\ufe0f Parse AI Response').item.json.company_name }}\nCampaign Type: {{ $('\u2699\ufe0f Parse AI Response').item.json.campaign_type }}\nChannel: {{ $('\u2699\ufe0f Parse AI Response').item.json.channel_requested }}\nBudget Mentioned: {{ $('\u2699\ufe0f Parse AI Response').item.json.proposed_budget }}\nTheir Ask: {{ $('\u2699\ufe0f Parse AI Response').item.json.key_details }}\nTone: {{ $('\u2699\ufe0f Parse AI Response').item.json.suggested_reply_tone }}\n\nWrite a short, professional, friendly reply (max 150 words) that:\n- Acknowledges their interest warmly\n- Asks for missing details: campaign brief, target audience, timeline, and budget if not provided\n- Says you will review and respond within 48 hours\n- Ends with a friendly sign-off\n\nReturn ONLY the email body text. No subject line.",
        "promptType": "define"
      },
      "typeVersion": 1.4
    },
    {
      "id": "96553d5f-a33f-448e-91bc-89376a5afaaf",
      "name": "\ud83d\udcf1 Telegram - New Deal Alert",
      "type": "n8n-nodes-base.telegram",
      "position": [
        3440,
        1200
      ],
      "webhookId": "1ab41ef6-f33d-4dbc-98e3-86b443e4762e",
      "parameters": {
        "text": "=\ud83c\udfaf *New Sponsorship Inquiry!*\n\n\ud83c\udfe2 *Company:* {{ $('\u2699\ufe0f Parse AI Response').item.json.company_name }}\n\ud83d\udc64 *Contact:* {{ $('\u2699\ufe0f Parse AI Response').item.json.contact_name }}\n\ud83d\udce7 *Email:* {{ $('\u2699\ufe0f Parse AI Response').item.json.email_from }}\n\ud83d\udcb0 *Budget:* {{ $('\u2699\ufe0f Parse AI Response').item.json.proposed_budget }}\n\ud83d\udcfa *Channel:* {{ $('\u2699\ufe0f Parse AI Response').item.json.channel_requested }}\n\ud83c\udfac *Campaign:* {{ $('\u2699\ufe0f Parse AI Response').item.json.campaign_type }}\n\ud83d\udcdd *Details:* {{ $('\u2699\ufe0f Parse AI Response').item.json.key_details }}\n\n---\n\u2709\ufe0f *Suggested Reply Draft:*\n{{ $json.text }}\n\n\u2705 Deal saved to Notion. Copy and send reply manually.",
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "typeVersion": 1.2
    },
