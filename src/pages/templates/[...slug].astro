---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScraperNodeBanner from '../../components/ScraperNodeBanner.astro';

export async function getStaticPaths() {
  const entries = await getCollection('templates');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const h1 = headings.find(h => h.depth === 1);
const title = h1?.text || entry.id.split('/').pop()?.replace(/-/g, ' ') || 'Template';
const description = `Ready-to-import n8n workflow template: ${title}. Download and automate in seconds.`;

const slug = entry.id;
const isScrapingRelated =
  slug.includes('web-scraping') ||
  slug.includes('scrape') ||
  slug.includes('http-request') ||
  title.toLowerCase().includes('scrape');
---

<BaseLayout title={title} description={description}>
  <ScraperNodeBanner show={isScrapingRelated} />
  <article>
    <Content />
  </article>
  <ScraperNodeBanner show={isScrapingRelated} />
</BaseLayout>
