<style>
  .hero { text-align: center; padding: 2rem 0; }
  .hero h1 { font-size: 2.25rem; background: linear-gradient(135deg, #ff6d5a, #ff8a65); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .hero-sub { font-size: 1.1rem; color: #6b7280; margin-top: 0.5rem; }
  .hero-stats { margin-top: 0.5rem; }
  .hero-actions { display: flex; gap: 0.75rem; justify-content: center; margin-top: 1.5rem; flex-wrap: wrap; }
  .btn { padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem; text-decoration: none; }
  .btn.primary { background: #ff6d5a; color: white; }
  .btn.scrapernode { background: linear-gradient(135deg, #ff6d5a, #ff8a65); color: white; }
  .btn.secondary { background: #f3f4f6; color: #374151; }
  .btn:hover { opacity: 0.9; }
</style>
